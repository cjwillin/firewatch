# Firewatch - Environment Configuration

# Database
DATABASE_URL=sqlite:///./firewatch.db

# SMTP Email Settings (required for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# API Key (optional, recommended for production)
# Protects POST/PUT/DELETE endpoints
API_KEY=your-secret-api-key-here

# Pushover (optional, for push notifications)
PUSHOVER_APP_TOKEN=your-pushover-app-token

# Scheduler Settings
POLL_INTERVAL_MINUTES=5

# Server
HOST=0.0.0.0
PORT=8000
